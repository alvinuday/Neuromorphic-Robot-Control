<?xml version="1.0" ?>
<mujoco model="xarm_6dof">
  <compiler angle="radian" inertiafromgeom="true" />
  <option timestep="0.002" gravity="0 0 -9.81" />

  <default>
    <geom rgba="0.75 0.78 0.82 1" />
    <default class="xarm">
      <geom contype="1" conaffinity="1" type="cylinder" />
      <joint type="hinge" damping="0.5" frictionloss="0.1" />
    </default>
  </default>

  <worldbody>
    <light name="key" pos="1.5 -1.2 2.2" dir="-0.6 0.4 -1" diffuse="1 1 1" specular="0.35 0.35 0.35"/>
    <light name="fill" pos="-1.2 1.0 1.6" dir="0.5 -0.3 -1" diffuse="0.6 0.6 0.7" specular="0.15 0.15 0.15"/>
    <geom name="floor" type="plane" pos="0 0 0" size="2 2 0.1" rgba="0.17 0.19 0.24 1"/>
    <camera name="cam_front" pos="1.75 -2.0 1.55" xyaxes="0.74 0.67 0  -0.34 0.38 0.86"/>
    <camera name="cam_side" pos="-2.2 -0.25 1.5" xyaxes="0.08 0.997 0  -0.57 0.05 0.82"/>
    <camera name="cam_far" pos="2.6 -2.8 2.0" xyaxes="0.73 0.68 0  -0.39 0.42 0.82"/>
    <camera name="cam_top" pos="0.0 -0.25 2.65" xyaxes="1 0 0  0 1 0"/>

    <!-- Table -->
    <body name="table" pos="0 0 0.4">
      <geom type="box" size="0.5 0.5 0.05" mass="10" rgba="0.32 0.34 0.38 1"/>
    </body>

    <!-- Red block on table -->
    <body name="red_block" pos="0.2 0.0 0.5">
      <geom type="box" size="0.03 0.03 0.03" mass="0.5" rgba="1 0 0 1" />
      <joint name="block_free" type="free" />
    </body>

    <!-- xArm base  -->
    <body name="xarm_base" pos="0 0 0.4">
      <geom type="sphere" size="0.05" mass="0.1" />

      <!-- Joint 1 (base yaw) -->
      <body name="link1" pos="0 0 0.05">
        <geom type="cylinder" size="0.04 0.1335" pos="0 0 0.1335" mass="1.2" />
        <joint name="joint1" type="hinge" axis="0 0 1" range="-6.283 6.283" damping="0.5" />

        <!-- Joint 2 (shoulder pitch) -->
        <body name="link2" pos="0 0 0.267">
          <geom type="cylinder" size="0.035 0.1445" pos="0 0 0.1445" mass="0.8" />
          <joint name="joint2" type="hinge" axis="0 1 0" range="-3.665 3.665" damping="0.4" />

          <!-- Joint 3 (shoulder roll) -->
          <body name="link3" pos="0 0 0.289">
            <geom type="cylinder" size="0.03 0.039" pos="0 0 0.039" mass="0.6" />
            <joint name="joint3" type="hinge" axis="1 0 0" range="-6.109 6.109" damping="0.4" />

            <!-- Joint 4 (elbow pitch) -->
            <body name="link4" pos="0 0 0.078">
              <geom type="cylinder" size="0.03 0.173" pos="0 0 0.173" mass="0.5" />
              <joint name="joint4" type="hinge" axis="0 1 0" range="-4.555 4.555" damping="0.3" />

              <!-- Joint 5 (wrist pitch) -->
              <body name="link5" pos="0 0 0.346">
                <geom type="cylinder" size="0.025 0.038" pos="0 0 0.038" mass="0.4" />
                <joint name="joint5" type="hinge" axis="0 1 0" range="-6.109 6.109" damping="0.2" />

                <!-- Joint 6 (wrist roll) -->
                <body name="link6" pos="0 0 0.076">
                  <geom type="cylinder" size="0.02 0.0485" pos="0 0 0.0485" mass="0.3" />
                  <joint name="joint6" type="hinge" axis="1 0 0" range="-6.283 6.283" damping="0.2" />

                  <!-- End-effector frame -->
                  <body name="gripper_base" pos="0 0 0.097">
                    <geom type="sphere" size="0.015" mass="0.1" />

                    <!-- Gripper left finger -->
                    <body name="gripper_left" pos="-0.01 0 0">
                      <geom type="box" size="0.005 0.005 0.02" pos="0 0 0.02" mass="0.05" />
                      <joint name="gripper_left" type="slide" axis="1 0 0" range="0 0.05" damping="0.1" />
                    </body>

                    <!-- Gripper right finger -->
                    <body name="gripper_right" pos="0.01 0 0">
                      <geom type="box" size="0.005 0.005 0.02" pos="0 0 0.02" mass="0.05" />
                      <joint name="gripper_right" type="slide" axis="-1 0 0" range="0 0.05" damping="0.1" />
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="1" ctrlrange="-20 20" />
    <motor name="joint2_motor" joint="joint2" gear="1" ctrlrange="-15 15" />
    <motor name="joint3_motor" joint="joint3" gear="1" ctrlrange="-15 15" />
    <motor name="joint4_motor" joint="joint4" gear="1" ctrlrange="-10 10" />
    <motor name="joint5_motor" joint="joint5" gear="1" ctrlrange="-8 8" />
    <motor name="joint6_motor" joint="joint6" gear="1" ctrlrange="-6 6" />
    <motor name="gripper_left_motor" joint="gripper_left" gear="1" ctrlrange="-5 5" />
    <motor name="gripper_right_motor" joint="gripper_right" gear="1" ctrlrange="-5 5" />
  </actuator>

  <sensor>
    <!-- Joint position sensors -->
    <jointpos name="J1" joint="joint1" />
    <jointpos name="J2" joint="joint2" />
    <jointpos name="J3" joint="joint3" />
    <jointpos name="J4" joint="joint4" />
    <jointpos name="J5" joint="joint5" />
    <jointpos name="J6" joint="joint6" />
    <!-- Joint velocity sensors -->
    <jointvel name="V1" joint="joint1" />
    <jointvel name="V2" joint="joint2" />
    <jointvel name="V3" joint="joint3" />
    <jointvel name="V4" joint="joint4" />
    <jointvel name="V5" joint="joint5" />
    <jointvel name="V6" joint="joint6" />
  </sensor>
</mujoco>

