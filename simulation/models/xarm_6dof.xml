<?xml version="1.0" ?>
<mujoco model="xarm_6dof">
  <!-- 
    xArm 6-DOF MuJoCo model for lerobot/utokyo_xarm_pick_and_place dataset replay.
    
    Configuration:
    - 6 arm joints (standard xArm architecture) + 1 parallel gripper
    - Matches dataset state/action dimensionality: state=[q1-q6,grip_l,grip_r], action=[v1-v6,grip_cmd]
    - Includes RGB cameras at multiple perspectives (84×84 resolution)
    - Includes 32-ray LiDAR via rangefinders
    - Includes event camera simulation hooks
    
    Reference: xArm technical spec + tech spec §5 (MuJoCo Environment)
  -->
  
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4" />
  
  <default>
    <joint damping="0.5" armature="0.02" frictionloss="0.1"/>
    <geom contype="1" conaffinity="1" friction="0.8 0.01 0.01"/>
    <motor ctrllimited="true"/>
  </default>
  
  <worldbody>
    <!-- Global lighting -->
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    
    <!-- Ground floor -->
    <geom name="floor" type="plane" pos="0 0 0" size="2 2 0.01" 
          rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1"/>
    
    <!-- Table surface (workspace) -->
    <body name="table" pos="0.5 0 0.3">
      <geom type="box" size="0.4 0.4 0.02" rgba="0.6 0.4 0.2 1"
            contype="1" conaffinity="1" mass="10"/>
      <site name="table_surface" pos="0 0 0.02" size="0.01"/>
    </body>
    
    <!-- Robot base (fixed to world) -->
    <body name="base" pos="0 0 0">
      <!-- Base cylinder -->
      <geom type="cylinder" fromto="0 0 0 0 0 0.05" size="0.08" 
            rgba="0.3 0.3 0.3 1" mass="2"/>
      
      <!-- ========== JOINT 1: Base Yaw (Z-axis rotation) ========== -->
      <body name="link1" pos="0 0 0.05">
        <joint name="joint1" type="hinge" axis="0 0 1" 
               range="-6.283 6.283" damping="1.0" frictionloss="0.05"/>
        <inertial pos="0 0 0.04" mass="1.5" diaginertia="0.005 0.005 0.003"/>
        <geom type="cylinder" fromto="0 0 0 0 0 0.08" size="0.045"
              rgba="0.2 0.4 0.8 1" mass="1.5"/>
        
        <!-- ========== JOINT 2: Shoulder Pitch (Y-axis rotation) ========== -->
        <body name="link2" pos="0 0 0.08">
          <joint name="joint2" type="hinge" axis="0 1 0" 
                 range="-3.665 3.665" damping="1.0" frictionloss="0.05"/>
          <inertial pos="0.1325 0 0" mass="1.2" diaginertia="0.007 0.012 0.012"/>
          <geom type="capsule" fromto="0 0 0 0.265 0 0" size="0.035"
                rgba="0.2 0.4 0.8 1" mass="1.2"/>
          
          <!-- ========== JOINT 3: Shoulder Roll (X-axis rotation) ========== -->
          <body name="link3" pos="0.265 0 0">
            <joint name="joint3" type="hinge" axis="1 0 0" 
                   range="-6.109 6.109" damping="0.9" frictionloss="0.04"/>
            <inertial pos="0 0 0.12" mass="1.0" diaginertia="0.008 0.008 0.004"/>
            <geom type="capsule" fromto="0 0 0 0 0 0.24" size="0.032"
                  rgba="0.2 0.4 0.8 1" mass="1.0"/>
            
            <!-- ========== JOINT 4: Elbow Pitch (Y-axis rotation) ========== -->
            <body name="link4" pos="0 0 0.24">
              <joint name="joint4" type="hinge" axis="0 1 0" 
                     range="-4.555 4.555" damping="0.8" frictionloss="0.04"/>
              <inertial pos="0.1225 0 0" mass="0.9" diaginertia="0.004 0.009 0.009"/>
              <geom type="capsule" fromto="0 0 0 0.245 0 0" size="0.028"
                    rgba="0.2 0.4 0.8 1" mass="0.9"/>
              
              <!-- ========== JOINT 5: Wrist Pitch (Y-axis rotation) ========== -->
              <body name="link5" pos="0.245 0 0">
                <joint name="joint5" type="hinge" axis="0 1 0" 
                       range="-6.109 6.109" damping="0.5" frictionloss="0.03"/>
                <inertial pos="0 0 0.06" mass="0.5" diaginertia="0.002 0.003 0.003"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.12" size="0.020"
                      rgba="0.3 0.5 0.9 1" mass="0.5"/>
                
                <!-- ========== JOINT 6: Wrist Roll (Z-axis rotation) ========== -->
                <body name="link6" pos="0 0 0.12">
                  <joint name="joint6" type="hinge" axis="0 0 1" 
                         range="-6.283 6.283" damping="0.4" frictionloss="0.02"/>
                  <inertial pos="0.025 0 0" mass="0.3" diaginertia="0.0008 0.0008 0.0005"/>
                  <geom type="capsule" fromto="0 0 0 0.05 0 0" size="0.015"
                        rgba="0.3 0.5 0.9 1" mass="0.3"/>
                  
                  <!-- ========== END EFFECTOR: Parallel Gripper ========== -->
                  <body name="ee_mount" pos="0.05 0 0">
                    <!-- Gripper palm (fixed reference) -->
                    <inertial pos="0 0 0" mass="0.1" diaginertia="0.0005 0.0005 0.0005"/>
                    <geom type="box" size="0.015 0.02 0.025"
                          rgba="0.8 0.5 0.2 1" mass="0.1"/>
                    
                    <!-- Left finger (moves in Y+) -->
                    <body name="gripper_left" pos="0 0.015 0">
                      <joint name="gripper_left" type="slide" axis="0 1 0"
                             range="0.0 0.05" damping="0.2" frictionloss="0.01"/>
                      <inertial pos="0 0.025 0" mass="0.08" diaginertia="0.00015 0.00015 0.00015"/>
                      <geom type="box" size="0.01 0.025 0.02" pos="0 0.025 0"
                            rgba="0.8 0.6 0.3 1" mass="0.08"/>
                      <site name="finger_left" pos="0 0.05 0" size="0.005"/>
                    </body>
                    
                    <!-- Right finger (moves in Y-) -->
                    <body name="gripper_right" pos="0 -0.015 0">
                      <joint name="gripper_right" type="slide" axis="0 -1 0"
                             range="0.0 0.05" damping="0.2" frictionloss="0.01"/>
                      <inertial pos="0 -0.025 0" mass="0.08" diaginertia="0.00015 0.00015 0.00015"/>
                      <geom type="box" size="0.01 0.025 0.02" pos="0 -0.025 0"
                            rgba="0.8 0.6 0.3 1" mass="0.08"/>
                      <site name="finger_right" pos="0 -0.05 0" size="0.005"/>
                    </body>
                    
                    <!-- End-effector reference site for kinematics and sensors -->
                    <site name="ee_site" pos="0 0 0" size="0.012" 
                          rgba="1 1 0 1"/>
                    
                    <!-- Wrist camera (eye-in-hand perspective) -->
                    <camera name="camera_wrist" pos="0.02 0 0.035" 
                            xyaxes="1 0 0 0 0 1" fovy="45"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
    
    <!-- ========== MANIPULANDUM: Medium object ========== -->
    <!-- Matches "pick and place" task in dataset -->
    <body name="object" pos="0.5 0.0 0.35">
      <freejoint name="object_joint"/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.00004 0.00004 0.00004"/>
      <geom type="cylinder" size="0.03 0.05" rgba="1 0.3 0.1 1" 
            mass="0.1" contype="1" conaffinity="1" friction="1.0"/>
      <site name="object_site" size="0.012" rgba="0 1 0 1"/>
    </body>
    
    <!-- ========== TARGET ZONE (visual marker) ========== -->
    <body name="target_zone" pos="0.5 0.3 0.4" mocap="true">
      <geom type="sphere" size="0.025" rgba="0 1 0 0.3" 
            contype="0" conaffinity="0"/>
    </body>
    
    <!-- ========== CAMERAS ========== -->
    <!-- Primary RGB camera: matches dataset perspective -->
    <camera name="camera_rgb" pos="0.6 0 0.9" 
            xyaxes="0 -1 0 -0.8 0 0.6" fovy="45"/>
    
    <!-- Side view for visualization -->
    <camera name="camera_side" pos="-0.2 1.0 0.6" 
            xyaxes="-1 0 0 0 -0.6 0.8" fovy="45"/>
  </worldbody>
  
  <!-- ========== ACTUATORS (joint motors) ========== -->
  <actuator>
    <!-- Six arm joint motors (torque-controlled) -->
    <motor name="act_j1" joint="joint1" gear="120" ctrlrange="-20 20"/>
    <motor name="act_j2" joint="joint2" gear="110" ctrlrange="-15 15"/>
    <motor name="act_j3" joint="joint3" gear="110" ctrlrange="-15 15"/>
    <motor name="act_j4" joint="joint4" gear="95"  ctrlrange="-10 10"/>
    <motor name="act_j5" joint="joint5" gear="80"  ctrlrange="-8 8"/>
    <motor name="act_j6" joint="joint6" gear="70"  ctrlrange="-6 6"/>
    <!-- Gripper motors (force-controlled, parallel drive) -->
    <motor name="act_gripper_left" joint="gripper_left" gear="25" ctrlrange="0 3"/>
    <motor name="act_gripper_right" joint="gripper_right" gear="25" ctrlrange="0 3"/>
  </actuator>
  
  <!-- ========== SENSORS ========== -->
  <sensor>
    <!-- Joint proprioception: positions (6-DOF) -->
    <jointpos name="q_j1" joint="joint1"/>
    <jointpos name="q_j2" joint="joint2"/>
    <jointpos name="q_j3" joint="joint3"/>
    <jointpos name="q_j4" joint="joint4"/>
    <jointpos name="q_j5" joint="joint5"/>
    <jointpos name="q_j6" joint="joint6"/>
    
    <!-- Gripper finger positions (2-DOF) -->
    <jointpos name="q_grip_left" joint="gripper_left"/>
    <jointpos name="q_grip_right" joint="gripper_right"/>
    
    <!-- Joint velocities (6-DOF) -->
    <jointvel name="qd_j1" joint="joint1"/>
    <jointvel name="qd_j2" joint="joint2"/>
    <jointvel name="qd_j3" joint="joint3"/>
    <jointvel name="qd_j4" joint="joint4"/>
    <jointvel name="qd_j5" joint="joint5"/>
    <jointvel name="qd_j6" joint="joint6"/>
    
    <!-- Gripper velocities (2-DOF) -->
    <jointvel name="qd_grip_left" joint="gripper_left"/>
    <jointvel name="qd_grip_right" joint="gripper_right"/>
    
    <!-- End-effector position (ground truth for kinematics evaluation) -->
    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
    
    <!-- Object position (ground truth for task evaluation) -->
    <framepos name="obj_pos" objtype="site" objname="object_site"/>
    
    <!-- ========== LiDAR via Rangefinders (32-ray dome) ========== -->
    <!-- Horizontal: 8 rays, Vertical: 4 layers = 32 rays total -->
    <!-- Layer 0 (elevation 0°) -->
    <rangefinder name="lidar_00_h0_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_01_h45_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_02_h90_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_03_h135_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_04_h180_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_05_h225_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_06_h270_v0" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_07_h315_v0" site="ee_site" cutoff="1.2"/>
    
    <!-- Layer 1 (elevation ~22.5°) -->
    <rangefinder name="lidar_08_h0_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_09_h45_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_10_h90_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_11_h135_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_12_h180_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_13_h225_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_14_h270_v1" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_15_h315_v1" site="ee_site" cutoff="1.2"/>
    
    <!-- Layer 2 (elevation ~45.0°) -->
    <rangefinder name="lidar_16_h0_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_17_h45_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_18_h90_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_19_h135_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_20_h180_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_21_h225_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_22_h270_v2" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_23_h315_v2" site="ee_site" cutoff="1.2"/>
    
    <!-- Layer 3 (elevation ~67.5°) -->
    <rangefinder name="lidar_24_h0_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_25_h45_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_26_h90_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_27_h135_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_28_h180_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_29_h225_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_30_h270_v3" site="ee_site" cutoff="1.2"/>
    <rangefinder name="lidar_31_h315_v3" site="ee_site" cutoff="1.2"/>
  </sensor>
  
</mujoco>
