<?xml version="1.0" ?>
<mujoco model="arm2dof">
  <compiler angle="radian" coordinate="local"/>
  
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <geom friction="1 0.5 0.5" margin="0.002"/>
    <joint limited="true" damping="0.1"/>
  </default>

  <worldbody>
    <!-- Ground -->
    <geom name="ground" type="plane" size="2 2 0.1" pos="0 0 -0.1"/>
    
    <!-- Base/Shoulder -->
    <body name="base" pos="0 0 0">
      <inertial mass="1.0" pos="0 0 0" 
                fullinertia="0.1 0.1 0.1 0 0 0"/>
      <geom type="sphere" size="0.05" rgba="0.8 0.8 0.8 1" mass="1.0"/>
      
      <!-- Shoulder joint (rotate around Y axis) -->
      <joint name="q0" type="hinge" pos="0 0 0" axis="0 1 0" 
             range="-3.14159 3.14159"/>
      
      <!-- Link 1 -->
      <body name="link1" pos="0 0 0">
        <inertial mass="1.0" pos="0.25 0 0" 
                  fullinertia="0.05 0.008 0.05 0 0 0"/>
        <geom name="link1" type="capsule" fromto="0 0 0 0.5 0 0" size="0.02" 
              rgba="0.8 0.3 0.3 1" mass="1.0"/>
        
        <!-- Elbow joint -->
        <joint name="q1" type="hinge" pos="0.5 0 0" axis="0 1 0" 
               range="-3.14159 3.14159"/>
        
        <!-- Link 2 -->
        <body name="link2" pos="0.5 0 0">
          <inertial mass="1.0" pos="0.25 0 0" 
                    fullinertia="0.05 0.008 0.05 0 0 0"/>
          <geom name="link2" type="capsule" fromto="0 0 0 0.5 0 0" size="0.02" 
                rgba="0.3 0.3 0.8 1" mass="1.0"/>
          
          <!-- End effector marker -->
          <geom name="end_effector" type="sphere" pos="0.5 0 0" size="0.03" 
                rgba="0.2 0.8 0.2 0.5"/>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>
    <motor name="tau0" joint="q0" gear="1" ctrlrange="-50 50"/>
    <motor name="tau1" joint="q1" gear="1" ctrlrange="-50 50"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <jointpos name="q0_pos" joint="q0"/>
    <jointpos name="q1_pos" joint="q1"/>
    <jointvel name="q0_vel" joint="q0"/>
    <jointvel name="q1_vel" joint="q1"/>
  </sensor>
</mujoco>
